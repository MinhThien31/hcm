# Copy this file to .env.local, then fill in your own keys.
# Do not commit real API keys.

# OpenAI / LLM
VITE_LLM_API_KEY=
VITE_LLM_BASE_URL=https://api.openai.com/v1
VITE_LLM_MODEL=gpt-5.4-mini

# OpenAI vector stores.
# Recommended:
# - VITE_HCM_CHAPTER3_VECTOR_STORE_ID: chapter 3 OCR + Session 10/11/12 notes.
# - VITE_HCM_TEXTBOOK_VECTOR_STORE_ID: optional wider textbook OCR store.
# VITE_VECTOR_STORE_ID is kept as a legacy fallback.
VITE_HCM_CHAPTER3_VECTOR_STORE_ID=
VITE_HCM_TEXTBOOK_VECTOR_STORE_ID=
VITE_VECTOR_STORE_ID=
VITE_FILE_SEARCH_MAX_RESULTS=6

